      "source": [
        "# ============================================================\n",
        "# TODO: Implement your RAG Pipeline class\n",
        "# ============================================================\n",
        "\n",
        "class RAGAssistant:\n",
        "    \"\"\"\n",
        "    A complete RAG-powered knowledge assistant.\n",
        "\n",
        "    Your implementation must include:\n",
        "    1. Document retrieval from ChromaDB\n",
        "    2. Answer generation using the QA model\n",
        "    3. Confidence-based response handling\n",
        "    4. Source attribution\n",
        "    \"\"\"\n",
        "\n",
        "    def __init__(self, collection, qa_model, confidence_threshold: float = 0.3):\n",
        "        \"\"\"\n",
        "        Initialize the RAG assistant.\n",
        "\n",
        "        Args:\n",
        "            collection: ChromaDB collection with embedded documents\n",
        "            qa_model: Hugging Face QA pipeline\n",
        "            confidence_threshold: Minimum confidence to provide a direct answer\n",
        "        \"\"\"\n",
        "        self.collection = collection\n",
        "        self.qa_model = qa_model\n",
        "        self.confidence_threshold = confidence_threshold\n",
        "\n",
        "    def retrieve(self, query: str, n_results: int = 3) -> Dict:\n",
        "        \"\"\"\n",
        "        Retrieve relevant documents for a query.\n",
        "\n",
        "        Args:\n",
        "            query: The user's question\n",
        "            n_results: Number of documents to retrieve\n",
        "\n",
        "        Returns:\n",
        "            Dict containing documents, metadatas, and ids\n",
        "        \"\"\"\n",
        "        results = self.collection.query(\n",
        "            query_texts=[query],\n",
        "            n_results=n_results,\n",
        "            include=['documents', 'metadatas']\n",
        "        )\n",
        "        return results\n",
        "\n",
        "    def generate_answer(self, question: str, context: str) -> Dict:\n",
        "        \"\"\"\n",
        "        Generate an answer from the given context.\n",
        "\n",
        "        Args:\n",
        "            question: The user's question\n",
        "            context: Retrieved context to answer from\n",
        "\n",
        "        Returns:\n",
        "            Dict with answer and confidence score\n",
        "        \"\"\"\n",
        "        if not context.strip():\n",
        "            return {\"answer\": \"I don't have enough information to answer that based on the provided context.\", \"score\": 0.0}\n",
        "\n",
        "        qa_input = {\n",
        "            'question': question,\n",
        "            'context': context\n",
        "        }\n",
        "        # Fix: Unpack dictionary using ** to provide named arguments to the pipeline\n",
        "        result = self.qa_model(**qa_input)\n",
        "        return {\"answer\": result['answer'], \"score\": result['score']}\n",
        "\n",
        "    def ask(self, question: str, n_results: int = 3) -> Dict:\n",
        "        \"\"\"\n",
        "        Complete RAG pipeline: retrieve and generate answer.\n",
        "        \"\"\"\n",
        "        retrieval_results = self.retrieve(question, n_results=n_results)\n",
        "\n",
        "        documents = retrieval_results['documents'][0]\n",
        "        metadatas = retrieval_results['metadatas'][0]\n",
        "\n",
        "        if not documents:\n",
        "            return {\n",
        "                \"question\": question,\n",
        "                \"answer\": \"I couldn't find any relevant information to answer your question.\",\n",
        "                \"confidence\": 0.0,\n",
        "                \"sources\": [],\n",
        "                \"is_confident\": False\n",
        "            }\n",
        "\n",
        "        context_parts = []\n",
        "        unique_sources = set()\n",
        "        for i, doc_content in enumerate(documents):\n",
        "            source_id = metadatas[i].get('source', 'Unknown Source')\n",
        "            chunk_index = metadatas[i].get('chunk_index', i)\n",
        "            context_parts.append(f\"[Source: {source_id}, Chunk {chunk_index}] {doc_content}\")\n",
        "            unique_sources.add(source_id)\n",
        "\n",
        "        combined_context = \"\\n\\n\".join(context_parts)\n",
        "\n",
        "        generation_output = self.generate_answer(question, combined_context)\n",
        "        answer = generation_output['answer']\n",
        "        confidence = generation_output['score']\n",
        "\n",
        "        is_confident = confidence >= self.confidence_threshold\n",
        "\n",
        "        if not is_confident:\n",
        "            answer = f\"I'm not confident enough to give a precise answer. My confidence score was {confidence:.2%}. You might want to rephrase your question.\"\n",
        "\n",
        "        return {\n",
        "            \"question\": question,\n",
        "            \"answer\": answer,\n",
        "            \"confidence\": confidence,\n",
        "            \"sources\": sorted(list(unique_sources)),\n",
        "            \"is_confident\": is_confident\n",
        "        }\n",
        "\n",
        "    def format_response(self, result: Dict) -> str:\n",
        "        \"\"\"\n",
        "        Format the result into a user-friendly response string.\n",
        "        \"\"\"\n",
        "        response_str = f\"Assistant: {result['answer']}\\n\"\n",
        "        response_str += f\"Confidence: {result['confidence']:.2%}\\n\"\n",
        "        if result['sources']:\n",
        "            response_str += f\"Sources: {', '.join(result['sources'])}\\n\"\n",
        "        return response_str\n",
        "\n",
        "# Create your assistant\n",
        "assistant = RAGAssistant(collection, qa_model, confidence_threshold=0.3)\n",
        "\n",
        "print(\"✅ RAG Assistant created!\")"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ RAG Assistant created!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "i8GhwlJn0t7e",
        "colab": {
          "base_uri": "https://localhost:8080/"
