        "    model_name=\"all-MiniLM-L6-v2\"\n",
        ")\n",
        "\n",
        "# Create or get your collection with a descriptive name\n",
        "# Use get_or_create_collection to prevent errors if it already exists\n",
        "collection = chroma_client.get_or_create_collection(\n",
        "    name=\"techgadgets_laptop_adapters\",  # Changed to a descriptive name\n",
