   &quot;source&quot;: [
    &quot;full_labels = pd.read_csv('/datasets/faces/labels.csv')\n&quot;,
    &quot;print(f\&quot;Total samples: {len(full_labels)}\&quot;)\n&quot;,
    &quot;print(f\&quot;Unique ages: {full_labels['real_age'].nunique()}\&quot;)\n&quot;,
    &quot;\n&quot;,
    &quot;\n&quot;,
    &quot;print(\&quot;\\nSplitting data (Random Split)...\&quot;)\n&quot;,
    &quot;train_df, temp_df = train_test_split(\n&quot;,
    &quot;    full_labels, \n&quot;,
    &quot;    test_size=0.3,       \n&quot;,
    &quot;    random_state=42,\n&quot;,
    &quot;    shuffle=True         \n&quot;,
    &quot;)\n&quot;,
    &quot;\n&quot;,
    &quot;val_df, test_df = train_test_split(\n&quot;,
    &quot;    temp_df, \n&quot;,
    &quot;    test_size=0.5,       \n&quot;,
    &quot;    random_state=42,\n&quot;,
    &quot;    shuffle=True\n&quot;,
    &quot;)\n&quot;,
    &quot;\n&quot;,
    &quot;print(f\&quot;Train set: {len(train_df)} ({len(train_df)/len(full_labels)*100:.1f}%)\&quot;)\n&quot;,
    &quot;print(f\&quot;Validation set: {len(val_df)} ({len(val_df)/len(full_labels)*100:.1f}%)\&quot;)\n&quot;,
    &quot;print(f\&quot;Test set: {len(test_df)} ({len(test_df)/len(full_labels)*100:.1f}%)\&quot;)\n&quot;,
    &quot;\n&quot;,
    &quot;base_path = '/datasets/faces/'\n&quot;,
    &quot;image_dir = os.path.join(base_path, 'final_files')\n&quot;,
    &quot;\n&quot;,
    &quot;\n&quot;,
    &quot;def load_generator(df, path, shuffle=True, augment=False):\n&quot;,
    &quot;    \&quot;\&quot;\&quot;Generic function to create a generator for any split\&quot;\&quot;\&quot;\n&quot;,
    &quot;    img_dir = os.path.join(path, 'final_files')\n&quot;,
    &quot;    \n&quot;,
    &quot;    if augment:\n&quot;,
    &quot;        datagen = ImageDataGenerator(\n&quot;,
    &quot;            rescale=1./255,\n&quot;,
    &quot;            rotation_range=20,\n&quot;,
    &quot;            width_shift_range=0.2,\n&quot;,
    &quot;            height_shift_range=0.2,\n&quot;,
    &quot;            shear_range=0.2,\n&quot;,
    &quot;            zoom_range=0.2,\n&quot;,
    &quot;            horizontal_flip=True\n&quot;,
    &quot;        )\n&quot;,
    &quot;    else:\n&quot;,
    &quot;        datagen = ImageDataGenerator(rescale=1./255)\n&quot;,
    &quot;    \n&quot;,
    &quot;    gen = datagen.flow_from_dataframe(\n&quot;,
    &quot;        dataframe=df,\n&quot;,
    &quot;        directory=img_dir,\n&quot;,
    &quot;        x_col='file_name',\n&quot;,
    &quot;        y_col='real_age',\n&quot;,
    &quot;        target_size=(224, 224),\n&quot;,
    &quot;        batch_size=32,\n&quot;,
    &quot;        class_mode='raw',\n&quot;,
    &quot;        shuffle=shuffle,\n&quot;,
    &quot;        seed=42\n&quot;,
    &quot;    )\n&quot;,
    &quot;    return gen\n&quot;,
    &quot;\n&quot;,
    &quot;print(\&quot;\\nCreating Generators...\&quot;)\n&quot;,
    &quot;train_gen = load_generator(train_df, base_path, shuffle=True, augment=True)\n&quot;,
    &quot;val_gen = load_generator(val_df, base_path, shuffle=False, augment=False)\n&quot;,
    &quot;test_gen = load_generator(test_df, base_path, shuffle=False, augment=False)\n&quot;,
    &quot;\n&quot;,
    &quot;print(\&quot;Generators created successfully!\&quot;)\n&quot;,
    &quot;print(f\&quot;Train batch shape: {next(train_gen)[0].shape}\&quot;)\n&quot;,
    &quot;print(f\&quot;Val batch shape: {next(val_gen)[0].shape}\&quot;)\n&quot;,
    &quot;print(f\&quot;Test batch shape: {next(test_gen)[0].shape}\&quot;)&quot;
   ]
