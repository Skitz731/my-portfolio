  {
   &quot;cell_type&quot;: &quot;code&quot;,
   &quot;execution_count&quot;: 5,
   &quot;metadata&quot;: {},
   &quot;outputs&quot;: [],
   &quot;source&quot;: [
    &quot;tf.random.set_seed(42)\n&quot;,
    &quot;np.random.seed(42)\n&quot;,
    &quot;\n&quot;,
    &quot;BASE_PATH = '/datasets/faces/'\n&quot;,
    &quot;IMAGE_DIR = os.path.join(BASE_PATH, 'final_files')\n&quot;,
    &quot;LABELS_PATH = os.path.join(BASE_PATH, 'labels.csv')\n&quot;,
    &quot;\n&quot;,
    &quot;VALIDATION_SPLIT = 0.2  \n&quot;,
    &quot;BATCH_SIZE = 32\n&quot;,
    &quot;IMG_SIZE = (224, 224)\n&quot;,
    &quot;\n&quot;,
    &quot;def load_train_generator(path, df, validation_split, seed):\n&quot;,
    &quot;    \&quot;\&quot;\&quot;\n&quot;,
    &quot;    Creates the Training Generator using validation_split.\n&quot;,
    &quot;    IMPORTANT: We use 'subset='training'' here.\n&quot;,
    &quot;    \&quot;\&quot;\&quot;\n&quot;,
    &quot;    img_dir = os.path.join(path, 'final_files')\n&quot;,
    &quot;    \n&quot;,
    &quot;    datagen = ImageDataGenerator(\n&quot;,
    &quot;        rescale=1./255,\n&quot;,
    &quot;        rotation_range=20,\n&quot;,
    &quot;        width_shift_range=0.2,\n&quot;,
    &quot;        height_shift_range=0.2,\n&quot;,
    &quot;        shear_range=0.2,\n&quot;,
    &quot;        zoom_range=0.2,\n&quot;,
    &quot;        horizontal_flip=True,\n&quot;,
    &quot;        validation_split=validation_split  \n&quot;,
    &quot;    )\n&quot;,
    &quot;    \n&quot;,
    &quot;    return datagen.flow_from_dataframe(\n&quot;,
    &quot;        dataframe=df,\n&quot;,
    &quot;        directory=img_dir,\n&quot;,
    &quot;        x_col='file_name',\n&quot;,
    &quot;        y_col='real_age',\n&quot;,
    &quot;        target_size=IMG_SIZE,\n&quot;,
    &quot;        batch_size=BATCH_SIZE,\n&quot;,
    &quot;        class_mode='raw',\n&quot;,
    &quot;        subset='training',  \n&quot;,
    &quot;        shuffle=True,\n&quot;,
    &quot;        seed=seed\n&quot;,
    &quot;    )\n&quot;,
    &quot;\n&quot;,
    &quot;def load_validation_generator(path, df, validation_split, seed):\n&quot;,
    &quot;    \&quot;\&quot;\&quot;\n&quot;,
    &quot;    Creates the Validation Generator using validation_split.\n&quot;,
    &quot;    IMPORTANT: We use 'subset='validation'' here.\n&quot;,
    &quot;    \&quot;\&quot;\&quot;\n&quot;,
    &quot;    img_dir = os.path.join(path, 'final_files')\n&quot;,
    &quot;    \n&quot;,
    &quot;    datagen = ImageDataGenerator(\n&quot;,
    &quot;        rescale=1./255,\n&quot;,
    &quot;        validation_split=validation_split  \n&quot;,
    &quot;    )\n&quot;,
    &quot;    \n&quot;,
    &quot;    return datagen.flow_from_dataframe(\n&quot;,
    &quot;        dataframe=df,\n&quot;,
    &quot;        directory=img_dir,\n&quot;,
    &quot;        x_col='file_name',\n&quot;,
    &quot;        y_col='real_age',\n&quot;,
    &quot;        target_size=IMG_SIZE,\n&quot;,
    &quot;        batch_size=BATCH_SIZE,\n&quot;,
    &quot;        class_mode='raw',\n&quot;,
    &quot;        subset='validation',  \n&quot;,
    &quot;        shuffle=False,        \n&quot;,
    &quot;        seed=seed\n&quot;,
    &quot;    )\n&quot;,
    &quot;\n&quot;,
    &quot;def create_model(input_shape=(224, 224, 3)):\n&quot;,
    &quot;    \&quot;\&quot;\&quot;Builds the ResNet50 model\&quot;\&quot;\&quot;\n&quot;,
    &quot;    base_model = ResNet50(weights='imagenet', include_top=False, input_shape=input_shape)\n&quot;,
    &quot;    base_model.trainable = False  \n&quot;,
    &quot;    \n&quot;,
    &quot;    model = Sequential([\n&quot;,
    &quot;        base_model,\n&quot;,
    &quot;        GlobalAveragePooling2D(),\n&quot;,
    &quot;        Dense(128, activation='relu'),\n&quot;,
    &quot;        Dropout(0.5),\n&quot;,
    &quot;        Dense(1)\n&quot;,
    &quot;    ])\n&quot;,
    &quot;    \n&quot;,
    &quot;    model.compile(\n&quot;,
    &quot;        optimizer=Adam(learning_rate=0.0005),\n&quot;,
    &quot;        loss='mse',\n&quot;,
    &quot;        metrics=['mae']\n&quot;,
    &quot;    )\n&quot;,
    &quot;    return model\n&quot;,
    &quot;\n&quot;,
    &quot;def train_model(model, train_gen, val_gen, epochs=20):\n&quot;,
    &quot;    \&quot;\&quot;\&quot;Trains the model with callbacks\&quot;\&quot;\&quot;\n&quot;,
    &quot;    callbacks = [\n&quot;,
    &quot;        tf.keras.callbacks.EarlyStopping(monitor='val_mae', patience=5, restore_best_weights=True),\n&quot;,
    &quot;        tf.keras.callbacks.ReduceLROnPlateau(monitor='val_mae', factor=0.5, patience=3, min_lr=1e-6)\n&quot;,
    &quot;    ]\n&quot;,
    &quot;    \n&quot;,
    &quot;    history = model.fit(\n&quot;,
    &quot;        train_gen,\n&quot;,
    &quot;        validation_data=val_gen,\n&quot;,
    &quot;        epochs=epochs,\n&quot;,
    &quot;        callbacks=callbacks\n&quot;,
    &quot;    )\n&quot;,
    &quot;    return history\n&quot;
   ]
  },
  {
